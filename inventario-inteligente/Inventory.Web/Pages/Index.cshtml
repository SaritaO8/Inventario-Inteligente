@page
@model Inventory.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Inventario Inteligente";
}

<div class="page-shell">
    <header class="hero">
        <div>
            <h1>Inventario Inteligente</h1>
            <p>Panel de administración para productos, inventario, ventas, facturas y chatbot.</p>
        </div>
        <button class="refresh-btn" onclick="loadAllData()">Actualizar</button>
    </header>

    <section class="card">
        <h2>Resumen general</h2>
        <div id="dashboard" class="stats-grid"></div>
    </section>

    <section class="card">
        <h2>Productos</h2>
        <form id="product-form" class="form-grid" onsubmit="handleCreateProduct(event)">
            <input id="productName" placeholder="Nombre" required />
            <input id="productCategory" placeholder="Categoría" required />
            <input id="productPrice" type="number" step="0.01" placeholder="Precio" required />
            <input id="productStock" type="number" placeholder="Stock" required />
            <label><input id="productActive" type="checkbox" checked /> Activo</label>
            <button type="submit">Crear producto</button>
        </form>
        <div id="products" class="table-wrap"></div>
    </section>

    <section class="card">
        <h2>Inventario</h2>
        <form id="inventory-form" class="form-grid" onsubmit="handleAdjustInventory(event)">
            <input id="inventoryProductId" placeholder="ID del producto" required />
            <input id="inventoryDelta" type="number" placeholder="Cambio de stock" required />
            <button type="submit">Ajustar stock</button>
        </form>
    </section>

    <section class="card">
        <h2>Ventas</h2>
        <form id="sale-form" class="form-grid" onsubmit="handleCreateSale(event)">
            <input id="saleProductId" placeholder="ID del producto" required />
            <input id="saleQuantity" type="number" placeholder="Cantidad" required />
            <input id="saleOrigin" placeholder="Origen" value="MANUAL" />
            <button type="submit">Registrar venta</button>
        </form>
        <div id="sales" class="table-wrap"></div>
    </section>

    <section class="card">
        <h2>Facturas</h2>
        <div id="invoices" class="table-wrap"></div>
    </section>

    <section class="card">
        <h2>Chatbot</h2>
        <form class="form-grid" onsubmit="sendMessage(event)">
            <input id="chatMessage" placeholder="Escribe tu mensaje" required />
            <button type="submit">Enviar</button>
        </form>
        <div id="chatResponse" class="chat-box"></div>
    </section>
</div>

@section Scripts {
<script src="~/app.js"></script>
}
